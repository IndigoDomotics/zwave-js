  "metadata": {
    "inclusion": "Tap the Z-Wave button 3 times quickly. The LED indicator will blink green to indicate communication. It will turn green for 3 seconds if inclusion is successful or red for 3 seconds if inclusion fails.",
    "exclusion": "Tap the Z-Wave button 3 times quickly. The LED indicator will blink green. It will turn green for 3 seconds when exclusion is complete.",
    "reset": "Press and hold the Z-Wave button for 20 seconds. The LED indicator will flash during the process and turn red for 3 seconds to confirm successful reset.",
